# Backend
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.0-flash
ALLOWED_ORIGINS=https://your-username.github.io,http://localhost:5173
DAILY_IP_CAP=40
# Optional Redis-backed rate limiting (Vercel KV / Upstash REST)
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Alternative Upstash variable names (if not using KV_*):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Frontend (set in frontend/.env)
# VITE_API_BASE_URL=https://your-vercel-project.vercel.app
